# deploy-production.sh が自動で読むデプロイ用設定ファイル。
# 本番サーバーではこのファイルを .env.deploy にコピーして値を埋める。

# API コンテナが読む本番 env。
ENV_FILE=.env

# deploy 後の smoke test 用 URL。
BASE_URL=https://api.example.com
FRONTEND_URL=https://app.example.com

# フロントは常に ./frontend-deploy に配置される。
# VITE_* はサーバー上の環境か frontend/.env.production に置く。
