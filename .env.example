# =====================================================
# Idol API 環境変数設定例
# cp .env.example .env してから値を編集してください
# =====================================================

# --- MongoDB 設定 ---
# ローカル開発: mongodb://localhost:27017
# Docker Compose: mongodb://admin:<password>@mongodb:27017/?authSource=admin
# MongoDB Atlas: mongodb+srv://<user>:<password>@<cluster>.mongodb.net
MONGODB_URI=mongodb://admin:password@localhost:27017/?authSource=admin
MONGODB_DATABASE=idol_database

# --- Docker Compose 用 MongoDB 認証 ---
MONGO_USERNAME=admin
MONGO_PASSWORD=change_me_in_production

# --- サーバー設定 ---
SERVER_PORT=8081

# --- 実行モード ---
# ローカル開発: debug
# 本番環境: release
GIN_MODE=debug

# --- CORS 設定 ---
# カンマ区切りで許可するオリジンを指定
# 本番環境ではフロントエンドのURLのみを許可すること
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# --- 管理者API認証キー ---
# 管理系API（削除申請管理等）へのアクセスに必要
# 本番環境では十分にランダムな値を設定すること（例: openssl rand -hex 32）
# Authorization: Bearer <ADMIN_API_KEY> ヘッダーで送信
ADMIN_API_KEY=change_me_to_a_secure_random_value
